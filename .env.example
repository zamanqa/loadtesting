# API Configuration — used by both Cypress and k6
API_BASE_URL=                        # Cypress: full base URL (e.g. https://hub-api-development-....run.app)
BASE_URL=                            # k6: full base URL (e.g. https://circuly-lumen.herokuapp.com)
API_VERSION=2026-04
CONSUMER_KEY=                        # e.g. ck_shopify_po
CONSUMER_SECRET=                     # e.g. cs_xxxxxxxxxxxxxxxx

# Company
COMPANY_ID=                          # e.g. 734f-4c766638po

# Database Configuration — Cypress cy.task('queryDb') only
DB_USER=
DB_PASSWORD=
DB_HOST=                             # e.g. your-db.rds.amazonaws.com
DB_NAME=postgres
DB_PORT=5432

# Cypress Cloud
CYPRESS_RECORD_KEY=                  # from https://cloud.cypress.io
