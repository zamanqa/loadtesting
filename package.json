    "products:load": "dotenv -- k6 run tests/load/products.load.test.js",
    "preretailers:load": "node -e \"require('fs').mkdirSync('tests/load/reports',{recursive:true})\"",
    "retailers:load": "dotenv -- k6 run tests/load/retailers.load.test.js",
    "prevouchers:load": "node -e \"require('fs').mkdirSync('tests/load/reports',{recursive:true})\"",
    "vouchers:load": "dotenv -- k6 run tests/load/vouchers.load.test.js",

    "all:smoke:cloud":               "node scripts/cloud-run.js tests/smoke/all-modules.smoke.test.js",
    "all:load:cloud":                "node scripts/cloud-run.js tests/load/all-modules.load.test.js",
    "all:stress:cloud":              "node scripts/cloud-run.js tests/stress/all-modules.stress.test.js",
