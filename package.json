    "customers:load:cloud":          "node scripts/cloud-run.js tests/load/customers.load.test.js",
    "invoices:load:cloud":           "node scripts/cloud-run.js tests/load/invoices.load.test.js",
    "transactions:load:cloud":       "node scripts/cloud-run.js tests/load/transactions.load.test.js",
    "draft-orders:load:cloud":       "node scripts/cloud-run.js tests/load/draft-orders.load.test.js",
    "recurring-payments:load:cloud": "node scripts/cloud-run.js tests/load/recurring-payments.load.test.js",
    "products:load:cloud":           "node scripts/cloud-run.js tests/load/products.load.test.js",
    "retailers:load:cloud":          "node scripts/cloud-run.js tests/load/retailers.load.test.js",
